@using eVote360Pro.Core.Domain.Common.Enums
@model UserViewModel
@{
	ViewData["Title"] = "Access Denied";
}

<div class="container-fluid mb-5 d-flex justify-content-center">
	<div class="card shadow-sm border-0 col-12 col-md-6">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0 text-center">Access Denied</h2>
		</div>

		<div class="card-body bg-white p-3">
			<div class="d-flex gap-2 flex-column text-center">
				<i class="bi bi-x-circle-fill text-warning display-3"></i>
				<h5 class="fs-3 fw-semibold">You do not have permission to access this section.</h5>

				<div class="col-12 d-flex justify-content-center">
					@if(Model is null)
					{
						<a asp-area="" asp-controller="VoterIdentity" asp-action="Index" class="btn btn-outline-warning col-12 col-md-4 fw-semibold">Go Home</a>
					}
					else if(Model.Role == UserRole.Admin)
					{
						<a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn btn-outline-warning col-12 col-md-4 fw-semibold">Go Home</a>
					}
					else if (Model.Role == UserRole.PoliticalLeader)
					{
						<a asp-area="PoliticalLeader" asp-controller="Home" asp-action="Index" class="btn btn-outline-warning col-12 col-md-4 fw-semibold">Go Home</a>
					}
				</div>
			</div>
		</div>
	</div>
</div>