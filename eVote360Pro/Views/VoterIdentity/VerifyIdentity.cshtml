@using eVote360Pro.Core.Application.ViewModels.VoterIdentity
@model IdentityVerificationViewModel
@{
	ViewData["Title"] = "Verify identification";
}

<div class="container-fluid mb-5 d-flex justify-content-center">
	<div class="card shadow-sm border-0 col-12 col-md-6">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0 text-center">Verify identification</h2>
		</div>

		<div class="card-body bg-white p-3">
			@Html.ValidationSummary(excludePropertyErrors: true, "", new { @class = "text-danger" })
			<form asp-area="" asp-controller="VoterIdentity" asp-action="VerifyIdentity" method="post" enctype="multipart/form-data">
				
				<div class="mb-2">
					<label asp-for="ImageFile" class="form-label fw-semibold">Document id:</label>
					<input asp-for="ImageFile" class="form-control" />
					<span asp-validation-for="ImageFile" class="text-danger"></span>
				</div>

				<div class="d-flex col-12 gap-2 justify-content-end pt-1">
					<a asp-area="" asp-controller="VoterIdentity" asp-action="Cancel" class="btn btn-outline-warning px-4 pt-2 fw-semibold">Cancel</a>
					<button type="submit" class="btn btn-outline-dark px-5 pt-2 fw-semibold">Verify identification</button>
				</div>
			</form>
		</div>
	</div>
</div>