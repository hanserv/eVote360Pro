@model FinalizeVotingViewModel
@{
    ViewData["Title"] = "Vote Page - Finalize Voting";
}


<div class="container-fluid mb-5 d-flex justify-content-center">
	<div class="card shadow-sm border-0 col-12 col-md-6">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0 text-center fw-semibold">Are you sure you want to finalize your voting process?</h2>
		</div>

		<div class="card-body bg-white p-3">
			@Html.ValidationSummary(excludePropertyErrors: true, "", new { @class = "text-danger" })
			<form asp-area="" asp-controller="Voting" asp-action="Finalize" method="post">
				<input type="hidden" asp-for="DocumentId" />

				<div class="d-flex col-12 gap-2 justify-content-end pt-1">
					<a asp-area="" asp-controller="Voting" asp-action="Index" class="btn btn-outline-warning px-4 pt-2 fw-semibold">Cancel</a>
					<button type="submit" class="btn btn-outline-dark px-5 pt-2 fw-semibold">Finalize Voting</button>
				</div>
			</form>
		</div>
	</div>
</div>