@using eVote360Pro.Core.Application.ViewModels.Election
@model ElectionSummaryPageViewModel
@{
	ViewData["Title"] = "Electoral Summary";
	var availableYears = ViewBag.AvailableYears as List<int> ?? [];
}

<div class="container-fluid mb-5 d-flex flex-column align-items-center gap-4">

	<div class="card shadow-sm border-0 col-12 col-md-6">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0 text-center">Select Election Summary by Year</h2>
		</div>

		<div class="card-body bg-white p-3">
			@Html.ValidationSummary(excludePropertyErrors: true, "", new { @class = "text-danger" })
			<form asp-area="Admin" asp-controller="Election" asp-action="Summary" method="post">

				<div class="mb-2">
					<label asp-for="SelectedYear" class="form-label fw-semibold">Election year:</label>

					<select asp-for="SelectedYear" class="form-select">
						@if (!availableYears.Any())
						{
							<option value="" disabled selected>There are no elections registered in the system.</option>
						}
						else
						{
							@foreach (var year in availableYears)
							{
								<option value="@year">@year</option>
							}
						}
					</select>
					<span asp-validation-for="SelectedYear" class="text-danger"></span>
				</div>

				<div class="d-flex col-12 gap-2 justify-content-end pt-1">
					<a asp-area="Admin" asp-controller="Home" asp-action="Index" class="btn btn-outline-dark fw-semibold"><i class="bi bi-arrow-left"></i> Go back</a>
					<button type="submit" class="btn btn-outline-dark px-5 pt-2 fw-semibold">Select</button>
				</div>
			</form>
		</div>
	</div>

	@if (Model.Summaries is not null)
	{
		<div class="card shadow-sm border-0 col-12 col-md-11 col-lg-10">
			<div class="card-header bg-dark text-white">
				<h3 class="fs-5 m-0 text-center fw-semibold">Elections registered in @Model.SelectedYear</h3>
			</div>

			<div class="card-body bg-white p-0">
				@if (!Model.Summaries.Any())
				{
					<div class="p-4 text-center text-muted fw-semibold fs-6">
						There are no registered elections for the selected year.
					</div>
				}
				else
				{
					<div class="table-responsive">
						<table class="table table-hover align-middle m-0 text-center">
							<thead class="table-light border-bottom border-dark-subtle">
								<tr class="text-secondary small fw-semibold">
									<th class="py-3 text-start ps-4">Election Name</th>
									<th class="py-3">Date</th>
									<th class="py-3">Total Parties</th>
									<th class="py-3">Total Candidates</th>
									<th class="py-3 pe-4">Total Voters</th>
								</tr>
							</thead>
							<tbody>
								@foreach (var summary in Model.Summaries)
								{
									<tr class="fw-normal">
										<td class="py-3 text-start ps-4 ">
											@summary.ElectionName
										</td>
										<td class="py-3">
											@($"{summary.RealizationDate:dd/MM/yyyy}")
										</td>
										<td class="py-3">
											@summary.TotalParticipatingParties
										</td>
										<td class="py-3">
											@summary.TotalParticipatingCandidates
										</td>
										<td class="py-3 pe-4">
											@summary.TotalCitizensVoted
										</td>
									</tr>
								}
							</tbody>
						</table>
					</div>
				}
			</div>
		</div>
	}
</div>
