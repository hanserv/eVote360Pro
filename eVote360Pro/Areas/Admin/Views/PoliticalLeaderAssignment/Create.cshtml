@model CreatePoliticalLeaderAssignmentViewModel
@{
	ViewData["Title"] = "Political Leader Assignation";
}

<div class="container-fluid mb-5 d-flex justify-content-center">
	<div class="card shadow-sm border-0 col-12 col-md-6">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0 text-center">Assign Political Leader</h2>
		</div>

		<div class="card-body bg-white p-3">
			@Html.ValidationSummary(excludePropertyErrors: true, "", new { @class = "text-danger" })
			<form asp-area="Admin" asp-controller="PoliticalLeaderAssignment" asp-action="Create" method="post">
				<div class="mb-2">
					<label asp-for="UserId" class="form-label fw-semibold">Leader:</label>
					<select asp-for="UserId" class="form-select">
						<option value="">Select a leader</option>
						@if (ViewBag.Users is not null)
						{
							foreach (var item in ViewBag.Users)
							{
								<option value="@item.Id">@($"{item.Name} - {item.Username}")</option>
							}
						}
					</select>
					<span asp-validation-for="UserId" class="text-danger"></span>
				</div>

				<div class="mb-2">
					<label asp-for="PoliticalPartyId" class="form-label fw-semibold">Political Party:</label>
					<select asp-for="PoliticalPartyId" class="form-select">
						<option value="">Select a political party</option>
						@if (ViewBag.PoliticalParties is not null)
						{
							foreach (var item in ViewBag.PoliticalParties)
							{
								<option value="@item.Id">@($"{item.Name} - {item.Acronym}")</option>
							}
						}
					</select>
					<span asp-validation-for="PoliticalPartyId" class="text-danger"></span>
				</div>

				<div class="d-flex col-12 gap-2 justify-content-end pt-1">
					<a asp-area="Admin" asp-controller="PoliticalLeaderAssignment" asp-action="Index" class="btn btn-outline-warning px-4 pt-2 fw-semibold">Go back</a>
					<button type="submit" class="btn btn-outline-dark px-5 pt-2 fw-semibold">Assign Leader</button>
				</div>
			</form>
		</div>
	</div>
</div>