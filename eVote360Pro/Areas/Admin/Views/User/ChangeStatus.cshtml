@model ChangeStatusUserViewModel
@{
	ViewData["Title"] = "Change Status User";
}

<div class="container-fluid mb-5 d-flex justify-content-center">
	<div class="card shadow-sm border-0 col-12 col-md-6">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0 text-center fw-semibold">Are you sure you want to change the status of the user <span class="fw-bold">@Model.Name</span> to @(Model.NewStatus ? "Active" : "Inactive")?</h2>
		</div>

		<div class="card-body bg-white p-3">
			@Html.ValidationSummary(excludePropertyErrors: true, "", new { @class = "text-danger" })
			<form asp-area="Admin" asp-controller="User" asp-action="ChangeStatus" method="post">
				<input type="hidden" asp-for="Id" />
				<input type="hidden" asp-for="Name" />
				<input type="hidden" asp-for="NewStatus" />

				<div class="d-flex col-12 gap-2 justify-content-end pt-1">
					<a asp-area="Admin" asp-controller="User" asp-action="Index" class="btn btn-outline-warning px-4 pt-2 fw-semibold">Cancel</a>
					<button type="submit" class="btn btn-outline-dark px-5 pt-2 fw-semibold">Change Status</button>
				</div>
			</form>
		</div>
	</div>
</div>