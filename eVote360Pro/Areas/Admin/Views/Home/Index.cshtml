@{
	ViewData["Title"] = "Admin Page";
}

<div class="container-fluid py-2">
	@* ---------- *@
	<div class="bg-light border-start border-4 border-warning rounded shadow-sm px-3 py-2 mb-4">
		<div class="d-flex align-items-center justify-content-between">
			<div>
				<h5 class="fw-bold mb-0">
					Admin Dashboard
				</h5>
				<small class="text-muted">
					Welcome back, <span class="fw-semibold">@ViewBag.CurrentUserName</span>
				</small>
			</div>

			<i class="bi bi-speedometer2 text-warning fs-4"></i>
		</div>
	</div>

	@* ---------- *@

	<div class="card border-warning shadow-sm mb-4">
		<div class="card-body d-flex justify-content-between align-items-center">
			<div>
				<h5 class="mb-1">Electoral Summary</h5>
				<p class="text-muted mb-0">Consult election results by year</p>
			</div>
			<a asp-area="Admin" asp-controller="Election" asp-action="Summary" class="btn btn-warning px-4 fw-semibold">
				Open
			</a>
		</div>
	</div>

	@* ---------- *@

	<div class="row g-4">
		<div class="col-md-4">
			<a asp-area="Admin" asp-controller="ElectivePosition" asp-action="Index" class="text-decoration-none">
				<div class="card border-warning shadow-sm h-100">
					<div class="card-body text-center">
						<i class="bi bi-person-rolodex fs-1 text-warning"></i>
						<h5 class="mt-3 text-dark">Elective Positions</h5>
					</div>
				</div>
			</a>
		</div>

		<div class="col-md-4">
			<a asp-area="Admin" asp-controller="Citizen" asp-action="Index" class="text-decoration-none">
				<div class="card border-warning shadow-sm h-100">
					<div class="card-body text-center">
						<i class="bi bi-people-fill fs-1 text-warning"></i>
						<h5 class="mt-3 text-dark">Citizens</h5>
					</div>
				</div>
			</a>
		</div>

		<div class="col-md-4">
			<a asp-area="Admin" asp-controller="PoliticalParty" asp-action="Index" class="text-decoration-none">
				<div class="card border-warning shadow-sm h-100">
					<div class="card-body text-center">
						<i class="bi bi-building-fill-gear fs-1 text-warning"></i>
						<h5 class="mt-3 text-dark">Political Parties</h5>
					</div>
				</div>
			</a>
		</div>

		<div class="col-md-4">
			<a asp-area="Admin" asp-controller="User" asp-action="Index" class="text-decoration-none">
				<div class="card border-warning shadow-sm h-100">
					<div class="card-body text-center">
						<i class="bi bi-person-fill-gear fs-1 text-warning"></i>
						<h5 class="mt-3 text-dark">Users</h5>
					</div>
				</div>
			</a>
		</div>

		<div class="col-md-4">
			<a asp-area="Admin" asp-controller="PoliticalLeaderAssignment" asp-action="Index" class="text-decoration-none">
				<div class="card border-warning shadow-sm h-100">
					<div class="card-body text-center">
						<i class="bi bi-diagram-3-fill fs-1 text-warning"></i>
						<h5 class="mt-3 text-dark">Political Leader Assignment</h5>
					</div>
				</div>
			</a>
		</div>

		<div class="col-md-4">
			<a asp-area="Admin" asp-controller="Election" asp-action="Index" class="text-decoration-none">
				<div class="card border-warning shadow-sm h-100">
					<div class="card-body text-center">
						<i class="bi bi-envelope-paper-fill fs-1 text-warning"></i>
						<h5 class="mt-3 text-dark">Elections</h5>
					</div>
				</div>
			</a>
		</div>

	</div>
</div>

@section Styles {
	<style>
		.card {
			transition: all .2s ease-in-out;
		}

			.card:hover {
				transform: translateY(-4px);
			}
	</style>
}