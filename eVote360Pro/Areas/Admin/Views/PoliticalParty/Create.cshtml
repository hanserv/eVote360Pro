@model CreatePoliticalPartyViewModel
@{
	ViewData["Title"] = "Create Political Party";
}

<div class="container-fluid mb-5 d-flex justify-content-center">
	<div class="card shadow-sm border-0 col-12 col-md-6">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0 text-center">New Political Party</h2>
		</div>

		<div class="card-body bg-white p-3">
			@Html.ValidationSummary(excludePropertyErrors: true, "", new { @class = "text-danger" })
			<form asp-area="Admin" asp-controller="PoliticalParty" asp-action="Create" method="post" enctype="multipart/form-data">
				<div class="mb-2">
					<label asp-for="Name" class="form-label fw-semibold">Name:</label>
					<input asp-for="Name" class="form-control" />
					<span asp-validation-for="Name" class="text-danger"></span>
				</div>

				<div class="mb-2">
					<label asp-for="Description" class="form-label fw-semibold">Description:</label>
					<input asp-for="Description" class="form-control" />
					<span asp-validation-for="Description" class="text-danger"></span>
				</div>

				<div class="mb-2">
					<label asp-for="Acronym" class="form-label fw-semibold">Acronym:</label>
					<input asp-for="Acronym" class="form-control" />
					<span asp-validation-for="Acronym" class="text-danger"></span>
				</div>

				<div class="mb-2">
					<label asp-for="LogoFile" class="form-label fw-semibold">Logo:</label>
					<input asp-for="LogoFile" class="form-control" />
					<span asp-validation-for="LogoFile" class="text-danger"></span>
				</div>

				<div class="d-flex col-12 gap-2 justify-content-end pt-1">
					<a asp-area="Admin" asp-controller="PoliticalParty" asp-action="Index" class="btn btn-outline-warning px-4 pt-2 fw-semibold">Go back</a>
					<button type="submit" class="btn btn-outline-dark px-5 pt-2 fw-semibold">Create political party</button>
				</div>
			</form>
		</div>
	</div>
</div>