@model IEnumerable<CandidateViewModel>
@{
	ViewData["Title"] = "Political Leader - Candidates";
	var showButtons = ViewBag.HasActiveElection ? false : true;
}

<div class="container-fluid mb-5">
	<div class="d-flex justify-content-between gap-2">
		<a asp-area="PoliticalLeader" asp-controller="Home" asp-action="Index" class="btn btn-outline-dark fw-semibold"><i class="bi bi-arrow-left"></i> Go back</a>
		<a asp-area="PoliticalLeader" asp-controller="Candidate" asp-action="Create" class="btn btn-outline-dark fw-semibold px-5 @(showButtons ? "" : "disabled")"><i class="bi bi-plus-lg"></i> Create candidate</a>
	</div>

	@if (!showButtons)
	{
		<div class="card bg-warning mt-2 p-2">
			<h5 class="fs-5 text-center text-light fw-normal m-0"><i class="bi bi-info-circle-fill"></i> Candidates cannot be modified while there is an active election.</h5>
		</div>
	}

	<div class="card shadow-sm border-0 mt-2">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0"><i class="bi bi-people-fill"></i> Candidates</h2>
		</div>

		<div class="card-body bg-white p-0">
			<div class="table-responsive">
				<table class="table table-bordered m-0 table-hover">
					<thead>
						<tr>
							<th>Photo</th>
							<th>Name</th>
							<th>Last Name</th>
							<th>Elective Position</th>
							<th>Status</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						@if (Model is not null)
						{
							foreach (var item in Model)
							{
								<tr>
									<td>
										<img src="/@item.Photo" alt="@item.Name Photo" width="50" height="50" class="img-fluid" />
									</td>
									<td>@item.Name</td>
									<td>@item.LastName</td>
									<td>@item.ElectivePositionName</td>
									<td>@(item.IsActive ? "Active" : "Inactive")</td>
									<td>
										<div class="d-flex gap-2">
											<a asp-area="PoliticalLeader" asp-controller="Candidate" asp-action="Edit" asp-route-id="@item.Id" class="@(showButtons ? "" : "pe-none")">
												<i class="bi bi-pencil-square text-warning fs-5"></i>
											</a>
											@if (item.IsActive)
											{
												<a asp-area="PoliticalLeader" asp-controller="Candidate" asp-action="ChangeStatus" asp-route-id="@item.Id" asp-route-active="false" class="btn btn-sm btn-outline-secondary @(showButtons ? "" : "disabled")">
													<span>Desactivate</span>
												</a>
											}
											else
											{
												<a asp-area="PoliticalLeader" asp-controller="Candidate" asp-action="ChangeStatus" asp-route-id="@item.Id" asp-route-active="true" class="btn btn-sm btn-outline-info @(showButtons ? "" : "disabled")">
													<span>Activate</span>
												</a>
											}
										</div>
									</td>
								</tr>
							}
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>