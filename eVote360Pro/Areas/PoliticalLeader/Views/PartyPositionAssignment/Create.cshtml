@model CreatePartyPositionAssignmentViewModel
@{
	ViewData["Title"] = "Add Party Position Assignment";
}

<div class="container-fluid mb-5 d-flex justify-content-center">
	<div class="card shadow-sm border-0 col-12 col-md-6">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0 text-center">Add Party Position Assignment</h2>
		</div>

		<div class="card-body bg-white p-3">
			@Html.ValidationSummary(excludePropertyErrors: true, "", new { @class = "text-danger" })
			<form asp-area="PoliticalLeader" asp-controller="PartyPositionAssignment" asp-action="Create" method="post">

				<div class="mb-2">
					<label asp-for="CandidateId" class="form-label fw-semibold">Candidate:</label>
					<select asp-for="CandidateId" class="form-select">
						<option value="">Select a candidate</option>
						@if (ViewBag.Candidates is not null)
						{
							foreach (var item in ViewBag.Candidates)
							{
								<option value="@item.Id">@($"{item.Name}")</option>
							}
						}
					</select>
					<span asp-validation-for="CandidateId" class="text-danger"></span>
				</div>

				<div class="mb-2">
					<label asp-for="ElectivePositionId" class="form-label fw-semibold">Elective Position:</label>
					<select asp-for="ElectivePositionId" class="form-select">
						<option value="">Select a elective position</option>
						@if (ViewBag.ElectivePositions is not null)
						{
							foreach (var item in ViewBag.ElectivePositions)
							{
								<option value="@item.Id">@($"{item.Name}")</option>
							}
						}
					</select>
					<span asp-validation-for="ElectivePositionId" class="text-danger"></span>
				</div>

				<div class="d-flex col-12 gap-2 justify-content-end pt-1">
					<a asp-area="PoliticalLeader" asp-controller="PartyPositionAssignment" asp-action="Index" class="btn btn-outline-warning px-4 pt-2 fw-semibold">Go back</a>
					<button type="submit" class="btn btn-outline-dark px-5 pt-2 fw-semibold">Add assignment</button>
				</div>
			</form>
		</div>
	</div>
</div>