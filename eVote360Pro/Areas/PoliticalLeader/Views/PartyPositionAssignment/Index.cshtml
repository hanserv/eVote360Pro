@model IEnumerable<AssignmentSummaryViewModel>
@{
	ViewData["Title"] = "Political Leader - Party Position Assignments";
	var showButtons = ViewBag.HasActiveElection ? false : true;
}

<div class="container-fluid mb-5">
	<div class="d-flex justify-content-between gap-2">
		<a asp-area="PoliticalLeader" asp-controller="Home" asp-action="Index" class="btn btn-outline-dark fw-semibold"><i class="bi bi-arrow-left"></i> Go back</a>
		<a asp-area="PoliticalLeader" asp-controller="PartyPositionAssignment" asp-action="Create" class="btn btn-outline-dark fw-semibold px-5 @(showButtons ? "" : "disabled")"><i class="bi bi-plus-lg"></i> Add Assignment</a>
	</div>

	@if (!showButtons)
	{
		<div class="card bg-warning mt-2 p-2">
			<h5 class="fs-5 text-center text-light fw-normal m-0"><i class="bi bi-info-circle-fill"></i> Candidate assignments cannot be modified while an election is active.</h5>
		</div>
	}

	<div class="card shadow-sm border-0 mt-2">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0"><i class="bi bi-diagram-3-fill"></i> Party Position Assignments</h2>
		</div>

		<div class="card-body bg-white p-0">
			<div class="table-responsive">
				<table class="table table-bordered m-0 table-hover">
					<thead>
						<tr>
							<th>Name</th>
							<th>Last Name</th>
							<th>Origin Party</th>
							<th>Elective Position</th>
							<th>Candidacy Type</th>
							<th>Actions</th>
						</tr>
					</thead>
					<tbody>
						@if (Model is not null)
						{
							foreach (var item in Model)
							{
								<tr>
									<td>@item.CandidateName</td>
									<td>@item.CandidateLastName</td>
									<td>@item.OriginPartyName</td>
									<td>@item.ElectivePositionName</td>
									<td>@item.CandidacyType</td>
									<td>
										<a asp-area="PoliticalLeader" asp-controller="PartyPositionAssignment" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger @(showButtons ? "" : "pe-none")">
											Delete relationship
										</a>
									</td>
								</tr>
							}
						}
					</tbody>
				</table>
			</div>
		</div>
	</div>
</div>