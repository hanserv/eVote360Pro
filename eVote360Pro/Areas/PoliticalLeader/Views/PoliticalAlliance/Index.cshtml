@{
	ViewData["Title"] = "Political Leader - Alliances Page";
}

<div class="container-fluid mb-5">
	<div class="d-flex mb-2">
		<a asp-area="PoliticalLeader" asp-controller="Home" asp-action="Index" class="btn btn-outline-dark fw-semibold"><i class="bi bi-arrow-left"></i> Go back</a>
	</div>

	<div class="card shadow-sm border-0 mt-2 no-hover">
		<div class="card-header bg-dark text-white">
			<h2 class="fs-4 m-0"><i class="bi bi-diagram-3-fill"></i> Political Alliances</h2>
		</div>

		<div class="card-body bg-white p-3">
			<div class="row g-4">
				<div class="col-md-4">
					<a asp-area="PoliticalLeader" asp-controller="PoliticalAlliance" asp-action="PendingRequests" class="text-decoration-none">
						<div class="card border-warning shadow-sm h-100">
							<div class="card-body text-center ">
								<i class="bi bi-hourglass fs-1 text-warning"></i>
								<h5 class="mt-3 text-dark">Pending requests</h5>
							</div>
						</div>
					</a>
				</div>

				<div class="col-md-4">
					<a asp-area="PoliticalLeader" asp-controller="PoliticalAlliance" asp-action="RequestsMade" class="text-decoration-none">
						<div class="card border-primary shadow-sm h-100">
							<div class="card-body text-center">
								<i class="bi bi-envelope-check-fill fs-1 text-primary"></i>
								<h5 class="mt-3 text-dark">Requests made</h5>
							</div>
						</div>
					</a>
				</div>

				<div class="col-md-4">
					<a asp-area="PoliticalLeader" asp-controller="PoliticalAlliance" asp-action="CurrentAlliances" class="text-decoration-none">
						<div class="card border-success shadow-sm h-100">
							<div class="card-body text-center">
								<i class="bi bi-send-check-fill fs-1 text-success"></i>
								<h5 class="mt-3 text-dark">Current alliances</h5>
							</div>
						</div>
					</a>
				</div>

			</div>
		</div>
	</div>
</div>

@section Styles {
	<style>
		.card {
			transition: all .2s ease-in-out;
		}

		.card:hover {
			transform: translateY(-4px);
		}

		.no-hover:hover{
			transform: none;
		}
	</style>
}