@using eVote360Pro.Core.Application.ViewModels.User
@model PoliticalLeaderDashboardViewModel
@{
	ViewData["Title"] = "Political Leader Page";
}

<div class="container-fluid py-2">
	<div class="bg-light border-start border-4 border-warning rounded shadow-sm px-3 py-2 mb-4">
		<div class="d-flex align-items-center justify-content-between">
			<div>
				<h5 class="fw-bold mb-0">
					Political Leader Dashboard
				</h5>
				<small class="text-muted">
					Welcome back, <span class="fw-semibold">@ViewBag.CurrentUserName</span>
				</small>
			</div>

			<i class="bi bi-speedometer2 text-warning fs-4"></i>
		</div>
	</div>

	<h4 class="fs-5 mb-2 text-secondary">Dashboard Indicators</h4>
	<div class="row g-4 mb-4">
		<div class="col-lg-4">
			<div class="card border-warning shadow-sm h-100">
				<div class="card-body d-flex flex-column justify-content-center align-items-center text-center">

					<img src="@Model.PoliticalPartyLogo"
						 alt="@Model.PoliticalPartyName"
						 class="img-fluid rounded mb-3"
						 style="max-height: 140px;" />

					<h3 class="fw-bold mb-1">
						@Model.PoliticalPartyName
					</h3>

					<span class="badge bg-warning text-dark fs-6 px-3 py-2">
						@Model.PoliticalPartyAcronym
					</span>

				</div>
			</div>
		</div>

		<div class="col-lg-8">
			<div class="row g-3">
				<div class="col-md-6 col-xl-4">
					<div class="card border-success shadow-sm h-100">
						<div class="card-body text-center">
							<i class="bi bi-person-check-fill fs-1 text-success"></i>
							<h2 class="fw-bold mt-2">@Model.TotalActiveCandidates</h2>
							<p class="mb-0 text-muted">Active Candidates</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-xl-4">
					<div class="card border-danger shadow-sm h-100">
						<div class="card-body text-center">
							<i class="bi bi-person-x-fill fs-1 text-danger"></i>
							<h2 class="fw-bold mt-2">@Model.TotalInactiveCandidates</h2>
							<p class="mb-0 text-muted">Inactive Candidates</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-xl-4">
					<div class="card border-primary shadow-sm h-100">
						<div class="card-body text-center">
							<i class="bi bi-send-check-fill fs-1 text-primary"></i>
							<h2 class="fw-bold mt-2">@Model.TotalPoliticalAlliances</h2>
							<p class="mb-0 text-muted">Political Alliances</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-xl-6">
					<div class="card border-warning shadow-sm h-100">
						<div class="card-body text-center">
							<i class="bi bi-hourglass fs-1 text-warning"></i>
							<h2 class="fw-bold mt-2">@Model.TotalPendingAllianceRequests</h2>
							<p class="mb-0 text-muted">Pending Alliance Requests</p>
						</div>
					</div>
				</div>

				<div class="col-md-6 col-xl-6">
					<div class="card border-info shadow-sm h-100">
						<div class="card-body text-center">
							<i class="bi bi-diagram-3-fill fs-1 text-info"></i>
							<h2 class="fw-bold mt-2">@Model.TotalAssignedCandidates</h2>
							<p class="mb-0 text-muted">Assigned Candidates</p>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>

	<h4 class="fs-5 mb-2 text-secondary">Management Menu</h4>
	<div class="row g-4">
		<div class="col-md-4">
			<a asp-area="PoliticalLeader" asp-controller="Candidate" asp-action="Index" class="text-decoration-none">
				<div class="card border-warning shadow-sm h-100">
					<div class="card-body text-center">
						<i class="bi bi-person-video2 fs-1 text-warning"></i>
						<h5 class="mt-3 text-dark">Candidates</h5>
					</div>
				</div>
			</a>
		</div>

		<div class="col-md-4">
			<a asp-area="PoliticalLeader" asp-controller="PoliticalAlliance" asp-action="Index" class="text-decoration-none">
				<div class="card border-warning shadow-sm h-100">
					<div class="card-body text-center">
						<i class="bi bi-send-check-fill fs-1 text-warning"></i>
						<h5 class="mt-3 text-dark">Political Alliances</h5>
					</div>
				</div>
			</a>
		</div>

		<div class="col-md-4">
			<a asp-area="PoliticalLeader" asp-controller="PartyPositionAssignment" asp-action="Index" class="text-decoration-none">
				<div class="card border-warning shadow-sm h-100">
					<div class="card-body text-center">
						<i class="bi bi-diagram-3-fill fs-1 text-warning"></i>
						<h5 class="mt-3 text-dark">Position Candidates Assignment </h5>
					</div>
				</div>
			</a>
		</div>

	</div>
</div>

@section Styles {
	<style>
		.card {
			transition: all .2s ease-in-out;
		}

		.card:hover {
			transform: translateY(-4px);
		}
	</style>
}